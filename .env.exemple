# Telegram Bot
TELEGRAM_TOKEN=your_telegram_token
BOT_MODE=polling
ADMIN_CHAT_ID=your_admin_chat_id

# Database
DATABASE_NAME=course
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# App Settings
NODE_ENV=development
LOG_LEVEL=debug
RUN_STANDALONE=true

# Optional for webhook:
# BOT_MODE=webhook
# WEBHOOK_URL=https://your_domain
# WEBHOOK_PORT=3000